# ── Application ──────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=MaSanteYa API
APP_URL=https://masanteya-api.railway.app
FRONTEND_URL=exp://192.168.1.x:8081

# ── Base de données ───────────────────────────────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ── JWT ──────────────────────────────────────────────────
JWT_ACCESS_SECRET=super_long_random_secret_min_64_chars_here_change_this_in_production
JWT_REFRESH_SECRET=another_super_long_random_secret_here_change_this_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Supabase ─────────────────────────────────────────────
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_SERVICE_KEY=[service_role_key]
SUPABASE_STORAGE_BUCKET=masanteya-files

# ── Redis (Upstash) ───────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://[REGION]-[ID].upstash.io
UPSTASH_REDIS_REST_TOKEN=[TOKEN]

# ── Email (Resend) ────────────────────────────────────────
RESEND_API_KEY=re_[KEY]
EMAIL_FROM=MaSanteYa <noreply@masanteya.app>

# ── SMS (Africa's Talking) ────────────────────────────────
AT_API_KEY=[KEY]
AT_USERNAME=masanteya
AT_ENVIRONMENT=sandbox

# ── Stockage (Cloudinary - optionnel) ─────────────────────
CLOUDINARY_CLOUD_NAME=[name]
CLOUDINARY_API_KEY=[key]
CLOUDINARY_API_SECRET=[secret]

# ── Sécurité ─────────────────────────────────────────────
BCRYPT_ROUNDS=12
OTP_EXPIRY_MINUTES=10
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15
CORS_ORIGINS=exp://localhost:8081,https://masanteya.app
